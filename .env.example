# =============================================================================
# AI Cloud Cost Detective - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Environment variables take precedence over .env file values.

# -----------------------------------------------------------------------------
# AWS Credentials (REQUIRED)
# -----------------------------------------------------------------------------

# AWS access key ID for authenticating API calls
AWS_ACCESS_KEY_ID=your-access-key-id

# AWS secret access key for authenticating API calls
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Default AWS region for the boto3 session (default: us-east-1)
AWS_DEFAULT_REGION=us-east-1

# Optional session token for temporary credentials (e.g., from STS AssumeRole)
# AWS_SESSION_TOKEN=your-session-token

# -----------------------------------------------------------------------------
# Scan Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of AWS regions to scan (default: us-east-1)
# Regional services (EC2, RDS, Lambda, DynamoDB, ELB) are scanned in each region.
# Global services (S3, CloudFront, IAM) are scanned once regardless of regions.
AWS_REGIONS=us-east-1

# Maximum number of concurrent AWS API calls during a scan (default: 10)
MAX_CONCURRENT_API_CALLS=10

# Maximum number of retry attempts for throttled API calls (default: 3)
MAX_RETRY_ATTEMPTS=3

# Maximum time in seconds for a complete scan before timeout (default: 300)
SCAN_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO
